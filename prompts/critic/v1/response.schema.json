{
  "type": "object",
  "additionalProperties": false,
  "required": ["run_id", "base_revision", "summary", "findings", "warnings", "unresolved", "recommended_next_action"],
  "properties": {
    "run_id": {"type": "string"},
    "base_revision": {"type": "integer", "minimum": 1},
    "summary": {"type": "string"},
    "findings": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "severity", "category", "affected_entity_ids", "claim", "evidence", "recommended_resolution"],
        "properties": {
          "id": {"type": "string"},
          "severity": {"type": "string", "enum": ["info", "low", "medium", "high", "blocking"]},
          "category": {"type": "string"},
          "affected_entity_ids": {"type": "array", "items": {"type": "string"}},
          "claim": {"type": "string"},
          "evidence": {"type": "string"},
          "recommended_resolution": {"type": "string"}
        }
      }
    },
    "warnings": {"type": "array", "items": {"type": "string"}},
    "unresolved": {"type": "array", "items": {"type": "string"}},
    "recommended_next_action": {"type": "string"}
  }
}
