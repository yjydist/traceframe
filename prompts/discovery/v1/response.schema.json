{
  "type": "object",
  "additionalProperties": false,
  "required": ["run_id", "base_revision", "summary", "commands", "warnings", "unresolved", "recommended_next_action"],
  "properties": {
    "run_id": {"type": "string"},
    "base_revision": {"type": "integer", "minimum": 1},
    "summary": {"type": "string"},
    "commands": {"type": "array", "minItems": 1, "maxItems": 100, "items": {"anyOf": [{"$ref": "#/$defs/create_entity_command"}, {"$ref": "#/$defs/create_relation_command"}]}},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "unresolved": {"type": "array", "items": {"type": "string"}},
    "recommended_next_action": {"type": "string"}
  },
  "$defs": {
    "create_entity_command": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "entity"],
      "properties": {
        "type": {"type": "string", "enum": ["create_entity"]},
        "entity": {"$ref": "#/$defs/entity"}
      }
    },
    "create_relation_command": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "relation"],
      "properties": {
        "type": {"type": "string", "enum": ["create_relation"]},
        "relation": {"$ref": "#/$defs/relation"}
      }
    },
    "entity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "title", "body", "status", "origin", "confidence", "freshness", "source_refs", "tags"],
      "properties": {
        "id": {"type": "string"},
        "kind": {"type": "string", "enum": ["goal", "stakeholder", "context", "scope_item", "constraint", "assumption", "question", "term", "scenario", "requirement", "quality_scenario", "risk", "option", "decision", "system_element", "work_slice", "experiment", "verification"]},
        "title": {"type": "string"},
        "body": {"anyOf": [{"$ref": "#/$defs/goal_body"}, {"$ref": "#/$defs/stakeholder_body"}, {"$ref": "#/$defs/context_body"}, {"$ref": "#/$defs/scope_body"}, {"$ref": "#/$defs/constraint_body"}, {"$ref": "#/$defs/assumption_body"}, {"$ref": "#/$defs/question_body"}, {"$ref": "#/$defs/term_body"}, {"$ref": "#/$defs/scenario_body"}, {"$ref": "#/$defs/requirement_body"}, {"$ref": "#/$defs/quality_scenario_body"}, {"$ref": "#/$defs/risk_body"}, {"$ref": "#/$defs/option_body"}, {"$ref": "#/$defs/decision_body"}, {"$ref": "#/$defs/system_element_body"}, {"$ref": "#/$defs/work_slice_body"}, {"$ref": "#/$defs/experiment_body"}, {"$ref": "#/$defs/verification_body"}]},
        "status": {"type": "string", "enum": ["proposed"]},
        "origin": {"type": "string", "enum": ["agent"]},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "freshness": {"type": "string", "enum": ["current"]},
        "source_refs": {"type": "array", "items": {"type": "string"}},
        "tags": {"type": "array", "items": {"type": "string"}}
      }
    },
    "relation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "from_id", "type", "to_id", "rationale"],
      "properties": {
        "id": {"type": "string"},
        "from_id": {"type": "string"},
        "type": {"type": "string", "enum": ["motivates", "affects", "constrains", "assumes", "answers", "derives_from", "satisfies", "verifies", "mitigates", "selects", "rejects", "depends_on", "conflicts_with", "supersedes", "implements", "decomposes", "evidenced_by"]},
        "to_id": {"type": "string"},
        "rationale": {"type": "string"}
      }
    },
    "goal_body": {
      "type": "object",
      "additionalProperties": false,
      "required": ["outcome", "success_signals", "time_horizon", "priority"],
      "properties": {
        "outcome": {"type": "string"},
        "success_signals": {"type": "array", "items": {"type": "string"}},
        "time_horizon": {"type": ["string", "null"]},
        "priority": {"type": "string", "enum": ["must", "should", "could"]}
      }
    },
    "stakeholder_body": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "interests", "authority", "impact", "contact_required"],
      "properties": {
        "role": {"type": "string"},
        "interests": {"type": "array", "items": {"type": "string"}},
        "authority": {"type": "string"},
        "impact": {"type": "string"},
        "contact_required": {"type": "boolean"}
      }
    },
    "context_body": {
      "type": "object",
      "additionalProperties": false,
      "required": ["current_state", "system_boundary", "external_dependencies", "baseline_behavior", "project_mode"],
      "properties": {
        "current_state": {"type": "string"},
        "system_boundary": {"type": "string"},
        "external_dependencies": {"type": "array", "items": {"type": "string"}},
        "baseline_behavior": {"type": "string"},
        "project_mode": {"type": "string", "enum": ["greenfield", "feature", "refactor", "spike"]}
      }
    },
    "scope_body": {
      "type": "object",
      "additionalProperties": false,
      "required": ["statement", "disposition", "rationale", "priority", "revisit_trigger"],
      "properties": {
        "statement": {"type": "string"},
        "disposition": {"type": "string", "enum": ["in_scope", "out_of_scope", "later"]},
        "rationale": {"type": "string"},
        "priority": {"type": ["string", "null"], "enum": ["must", "should", "could", null]},
        "revisit_trigger": {"type": ["string", "null"]}
      }
    },
    "constraint_body": {
      "type": "object",
      "additionalProperties": false,
      "required": ["category", "statement", "hard", "rationale"],
      "properties": {
        "category": {"type": "string", "enum": ["time", "budget", "technology", "compatibility", "legal", "organizational", "operational", "physical"]},
        "statement": {"type": "string"},
        "hard": {"type": "boolean"},
        "rationale": {"type": "string"}
      }
    },
    "assumption_body": {
      "type": "object",
      "additionalProperties": false,
      "required": ["statement", "impact_if_false", "validation_method", "expires_at", "owner"],
      "properties": {
        "statement": {"type": "string"},
        "impact_if_false": {"type": "string", "enum": ["low", "medium", "high", "critical"]},
        "validation_method": {"type": "string"},
        "expires_at": {"type": ["string", "null"]},
        "owner": {"type": "string"}
      }
    },
    "question_body": {
      "type": "object",
      "additionalProperties": false,
      "required": ["prompt", "reason", "answer_type", "options", "impact", "uncertainty", "irreversibility", "blocking", "answer", "disposition"],
      "properties": {
        "prompt": {"type": "string"},
        "reason": {"type": "string"},
        "answer_type": {"type": "string"},
        "options": {"type": ["array", "null"], "items": {"type": "string"}},
        "impact": {"type": "integer", "minimum": 1, "maximum": 5},
        "uncertainty": {"type": "integer", "minimum": 1, "maximum": 5},
        "irreversibility": {"type": "integer", "minimum": 1, "maximum": 5},
        "blocking": {"type": "boolean"},
        "answer": {"type": "null"},
        "disposition": {"type": "string", "enum": ["open"]}
      }
    },
    "term_body": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "definition", "aliases", "scope", "source_ref"],
      "properties": {
        "name": {"type": "string"},
        "definition": {"type": "string"},
        "aliases": {"type": "array", "items": {"type": "string"}},
        "scope": {"type": "string"},
        "source_ref": {"type": ["string", "null"]}
      }
    },
    "scenario_body": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actor", "trigger", "preconditions", "main_flow", "alternative_flows", "failure_flows", "postconditions", "frequency", "importance"],
      "properties": {
        "actor": {"type": "string"},
        "trigger": {"type": "string"},
        "preconditions": {"type": "array", "items": {"type": "string"}},
        "main_flow": {"type": "array", "items": {"type": "string"}},
        "alternative_flows": {"type": "array", "items": {"type": "string"}},
        "failure_flows": {"type": "array", "items": {"type": "string"}},
        "postconditions": {"type": "array", "items": {"type": "string"}},
        "frequency": {"type": "string"},
        "importance": {"type": "string"}
      }
    },
    "requirement_body": {
      "type": "object",
      "additionalProperties": false,
      "required": ["statement", "category", "rationale", "acceptance_conditions", "priority", "stability"],
      "properties": {
        "statement": {"type": "string"},
        "category": {"type": "string", "enum": ["functional", "constraint", "interface", "data", "operational"]},
        "rationale": {"type": "string"},
        "acceptance_conditions": {"type": "array", "items": {"type": "string"}},
        "priority": {"type": "string", "enum": ["must", "should", "could"]},
        "stability": {"type": "string", "enum": ["stable", "evolving", "volatile"]}
      }
    },
    "quality_scenario_body": {
      "type": "object",
      "additionalProperties": false,
      "required": ["characteristic", "source", "stimulus", "environment", "artifact", "response", "measure"],
      "properties": {
        "characteristic": {"type": "string"},
        "source": {"type": "string"},
        "stimulus": {"type": "string"},
        "environment": {"type": "string"},
        "artifact": {"type": "string"},
        "response": {"type": "string"},
        "measure": {"type": "string"}
      }
    },
    "risk_body": {
      "type": "object",
      "additionalProperties": false,
      "required": ["category", "cause", "event", "impact", "likelihood", "severity", "mitigation", "evidence_needed", "residual_risk"],
      "properties": {
        "category": {"type": "string", "enum": ["value", "usability", "feasibility", "architecture", "security", "privacy", "delivery", "operational", "compliance"]},
        "cause": {"type": "string"},
        "event": {"type": "string"},
        "impact": {"type": "string"},
        "likelihood": {"type": "string"},
        "severity": {"type": "string"},
        "mitigation": {"type": "string"},
        "evidence_needed": {"type": "array", "items": {"type": "string"}},
        "residual_risk": {"type": "string"}
      }
    },
    "option_body": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision_topic", "description", "benefits", "costs", "risks", "fit_to_constraints", "evidence_refs"],
      "properties": {
        "decision_topic": {"type": "string"},
        "description": {"type": "string"},
        "benefits": {"type": "array", "items": {"type": "string"}},
        "costs": {"type": "array", "items": {"type": "string"}},
        "risks": {"type": "array", "items": {"type": "string"}},
        "fit_to_constraints": {"type": "array", "items": {"type": "string"}},
        "evidence_refs": {"type": "array", "items": {"type": "string"}}
      }
    },
    "decision_body": {
      "type": "object",
      "additionalProperties": false,
      "required": ["question", "selected_option_id", "rationale", "consequences", "alternatives_considered", "revisit_triggers", "significance", "approval_required"],
      "properties": {
        "question": {"type": "string"},
        "selected_option_id": {"type": "string"},
        "rationale": {"type": "string"},
        "consequences": {"type": "array", "items": {"type": "string"}},
        "alternatives_considered": {"type": "array", "items": {"type": "string"}},
        "revisit_triggers": {"type": "array", "items": {"type": "string"}},
        "significance": {"type": "string", "enum": ["local", "cross_cutting", "architectural"]},
        "approval_required": {"type": "boolean"}
      }
    },
    "system_element_body": {
      "type": "object",
      "additionalProperties": false,
      "required": ["element_type", "responsibilities", "boundary", "technology", "lifecycle", "trust_zone"],
      "properties": {
        "element_type": {"type": "string", "enum": ["person", "software_system", "container", "component", "interface", "datastore", "external_system"]},
        "responsibilities": {"type": "array", "items": {"type": "string"}},
        "boundary": {"type": "string"},
        "technology": {"type": ["string", "null"]},
        "lifecycle": {"type": "string"},
        "trust_zone": {"type": ["string", "null"]}
      }
    },
    "work_slice_body": {
      "type": "object",
      "additionalProperties": false,
      "required": ["outcome", "included", "excluded", "dependencies", "verification_refs", "risk_reduction", "completion_conditions", "order_hint"],
      "properties": {
        "outcome": {"type": "string"},
        "included": {"type": "array", "items": {"type": "string"}},
        "excluded": {"type": "array", "items": {"type": "string"}},
        "dependencies": {"type": "array", "items": {"type": "string"}},
        "verification_refs": {"type": "array", "items": {"type": "string"}},
        "risk_reduction": {"type": "string"},
        "completion_conditions": {"type": "array", "items": {"type": "string"}},
        "order_hint": {"type": "number", "minimum": 0}
      }
    },
    "experiment_body": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hypothesis", "decision_criteria", "method", "inputs", "time_box", "safety_constraints", "expected_evidence", "result_evidence_refs", "conclusion"],
      "properties": {
        "hypothesis": {"type": "string"},
        "decision_criteria": {"type": "array", "items": {"type": "string"}},
        "method": {"type": "string"},
        "inputs": {"type": "array", "items": {"type": "string"}},
        "time_box": {"type": "string"},
        "safety_constraints": {"type": "array", "items": {"type": "string"}},
        "expected_evidence": {"type": "array", "items": {"type": "string"}},
        "result_evidence_refs": {"type": "array", "items": {"type": "string"}},
        "conclusion": {"type": ["string", "null"]}
      }
    },
    "verification_body": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_ref", "method", "procedure", "expected_result", "environment", "owner"],
      "properties": {
        "target_ref": {"type": "string"},
        "method": {"type": "string", "enum": ["test", "review", "analysis", "demonstration", "measurement", "experiment"]},
        "procedure": {"type": "string"},
        "expected_result": {"type": "string"},
        "environment": {"type": "string"},
        "owner": {"type": "string"}
      }
    }
  }
}
